{
  "name": "sc-telemetry-hub",
  "version": "0.1.0",
  "description": "Star Citizen Telemetry Hub - Haptic telemetry bridge",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "author": "Romain Fleury",
  "scripts": {
    "dev": "concurrently \"yarn:dev:renderer\" \"yarn:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "build": "vite build",
    "build:electron": "yarn build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder",
    "start": "electron ."
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.9.6"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.3",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^32.1.2",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "wait-on": "^7.2.0"
  },
  "packageManager": "yarn@4.11.0"
}
